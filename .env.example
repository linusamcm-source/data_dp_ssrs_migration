# ---------------------------------------------------------------------------
# RsMigration configuration template (PowerShell-only toolkit).
#
# Copy this file to ".env" and fill in your values:
#     copy .env.example .env        (Windows)
#     cp   .env.example .env        (bash)
#
# run.bat loads ".env" automatically before "dry-run"/"migrate" and threads
# every variable below into the Invoke-RsMigration cmdlet. See README.md for
# full descriptions.
#
# AUTH: all connections (SQL via dbatools, REST via ReportingServicesTools) use
# Windows INTEGRATED SECURITY — they run as the current Windows identity
# (e.g. MYSTATE\lc.admin). There are NO usernames, passwords, Key Vault names,
# or storage keys in this file. The only secret is the encryption-key password,
# which is never stored here — it is passed as a SecureString parameter and
# prompted interactively when omitted.
#
# NO HARDCODED PATHS: share ROOTS and FILE NAMES are separate variables. Code
# joins "<share>\<file-name>" at runtime, so nothing is a baked-in full path.
#
# Rules (parsed by run.bat, a plain batch loader):
#   - KEY=VALUE, one per line. Do NOT quote values; no spaces around "=".
#   - Lines starting with "#" are comments.
#   - Never commit a real ".env" — it is git-ignored.
# ---------------------------------------------------------------------------

# --- Report portals (REST, integrated security) ----------------------------
# SOURCE (legacy SSRS) report portal root URL.
RS_SOURCE_PORTAL_URI=https://ssrs-source.example.int/reports
# TARGET (Power BI Report Server) report portal root URL.
RS_TARGET_PORTAL_URI=https://pbirs-target.example.int/reports

# --- SQL instances (integrated security) ------------------------------------
# SOURCE SQL instance the ReportServer DBs are backed up FROM (phase B7).
RS_SOURCE_SQL_INSTANCE=ssrs-source.example.int
# TARGET SQL instance the ReportServer DBs are restored ONTO (phase B8).
RS_TARGET_SQL_INSTANCE=pbirs-target.example.int
# SQL server PBIRS is pointed at after restore (phase B9).
RS_DATABASE_SERVER_NAME=pbirs-target.example.int
# ReportServer database name to bind (B9) and clean (B11).
RS_DATABASE_NAME=ReportServer

# --- Fileshares (SMB :445) — share ROOTS only, no file names ----------------
# SOURCE machine fileshare: DB backups and the .snk are written here first.
RS_SOURCE_SHARE=\\ssrs-source.example.int\FileShare
# TARGET machine fileshare: backups are copied here, then restored from here.
RS_TARGET_SHARE=\\pbirs-target.example.int\FileShare

# --- Transferred file NAMES (joined to the share roots above) ---------------
# Encryption-key file name (Backup/Restore-RsEncryptionKey).
RS_KEY_FILE=ReportServer.snk
# ReportServer database backup file name.
RS_REPORTSERVER_BAK=ReportServer.bak
# ReportServerTempDB database backup file name.
RS_REPORTSERVERTEMPDB_BAK=ReportServerTempDB.bak

# --- Stale-key cleanup safety (phase B11) -----------------------------------
# Stale SOURCE machine whose dbo.Keys row is removed.
RS_STALE_MACHINE_NAME=ssrs-source
# Active TARGET machine that must NEVER be deleted.
RS_ACTIVE_MACHINE_NAME=pbirs-target

# --- Validation targets (phase C) -------------------------------------------
# Comma-separated catalog-item ids to render-test.
RS_REPORTS=Orders,ExecutiveSummary
# Comma-separated data-source ids to probe for connectivity.
RS_DATA_SOURCES=Sales,HR

# --- Subscription import filter ---------------------------------------------
# Comma-separated subscription names to import (exclude all others).
# Leave EMPTY to import ALL subscriptions.
RS_INCLUDE_SUBSCRIPTIONS=

# --- Run mode (optional) ----------------------------------------------------
# Set to 1/true/yes/on to run ONLY the read-only phases (no mutations).
RS_DRY_RUN=
