# ---------------------------------------------------------------------------
# rs-migration configuration template.
#
# Copy this file to ".env" and fill in your values:
#     copy .env.example .env        (Windows)
#     cp   .env.example .env        (bash)
#
# run.bat loads ".env" automatically before running the migration. Every
# variable below maps 1:1 to an "rs-migration" CLI flag (the env var is the
# default; an explicit flag overrides it). See README.md for full descriptions.
#
# Rules for this file (it is parsed by run.bat, a plain batch loader):
#   - KEY=VALUE, one per line.
#   - Do NOT quote values and do NOT put spaces around "=".
#   - Lines starting with "#" are comments.
#   - Never commit a real ".env" — it is git-ignored and holds secrets.
# ---------------------------------------------------------------------------

# --- Target PBIRS server (REST) --------------------------------------------
# Hostname only — no scheme, no path. (--server)
RS_SERVER=pbirs.contoso.com
# URL scheme for the report server: http | https. (--scheme)
RS_SCHEME=https

# --- Azure Key Vault + encryption key --------------------------------------
# Key Vault NAME (not URL) holding the stored secrets. (--vault)
RS_VAULT=kv-rs-migration
# Filesystem path of the .snk encryption key on the report-server host. (--key-path)
RS_KEY_PATH=C:\rs\ReportServer.snk
# Key Vault secret NAME holding the encryption-key password. (--key-password-secret)
RS_KEY_PASSWORD_SECRET=rsKeyPassword
# Key Vault secret NAME the base64-encoded .snk is pushed to. (--snk-secret)
RS_SNK_SECRET=rsSnk

# --- SQL instances ----------------------------------------------------------
# SOURCE SQL instance the ReportServer DBs are backed up FROM (phase B7). (--source-sql-instance)
RS_SOURCE_SQL_INSTANCE=SRC\SQL
# TARGET SQL instance the ReportServer DBs are restored ONTO (phase B8). (--target-sql-instance)
RS_TARGET_SQL_INSTANCE=TGT\SQL
# SQL server PBIRS is pointed at after restore (phase B9). (--database-server-name)
RS_DATABASE_SERVER_NAME=TGT\SQL
# ReportServer database name to bind (B9) and clean (B11). (--database-name)
RS_DATABASE_NAME=ReportServer

# --- Blob backup storage ----------------------------------------------------
# Blob container URL backups are written to / restored from. (--azure-base-url)
RS_AZURE_BASE_URL=https://mystorage.blob.core.windows.net/rs-backups
# Blob-auth model: SAS | StorageKey | ManagedIdentity. (--blob-model)
RS_BLOB_MODEL=SAS

# --- Stale-key cleanup safety (phase B11) -----------------------------------
# Stale SOURCE machine whose dbo.Keys row is removed. (--stale-machine-name)
RS_STALE_MACHINE_NAME=OLD-SSRS
# Active TARGET machine that must NEVER be deleted. (--active-machine-name)
RS_ACTIVE_MACHINE_NAME=NEW-PBIRS

# --- Validation targets (phase C) -------------------------------------------
# Comma-separated catalog-item ids to render-test. (--report, repeatable)
RS_REPORTS=Orders,ExecutiveSummary
# Comma-separated data-source ids to probe for connectivity. (--data-source, repeatable)
RS_DATA_SOURCES=Sales,HR

# --- NTLM auth (optional) ---------------------------------------------------
# NTLM username (domain\user); enables NTLM when set. (--username)
RS_USERNAME=
# NTLM password (with RS_USERNAME). (--password)
RS_PASSWORD=

# --- Run mode (optional) ----------------------------------------------------
# Set to 1/true/yes/on to run ONLY the read-only phases (no mutations). (--dry-run)
RS_DRY_RUN=
