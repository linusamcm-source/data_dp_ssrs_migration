<mxfile host="65bd71144e" pages="2">
    <diagram id="ssrs-pbirs-arch" name="SSRS to PBIRS Migration">
        <mxGraphModel dx="3118" dy="684" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1760" pageHeight="1120" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="title" value="SSRS → PBIRS Migration Toolkit — Invoke-RsMigration 9-phase PowerShell runbook and source/target server interaction" style="text;html=1;align=left;verticalAlign=middle;fontStyle=1;fontSize=18;" parent="1" vertex="1">
                    <mxGeometry x="40" y="20" width="1300" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="C_PS" value="PowerShell module — RsMigration/  (RootModule RsMigration.psm1 · auto-export Public/*.ps1 · RequiredModules: ReportingServicesTools, dbatools · PS 7.0+)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#82b366;dashed=1;verticalAlign=top;align=left;spacingLeft=10;spacingTop=6;fontStyle=1;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="340" y="90" width="620" height="920" as="geometry"/>
                </mxCell>
                <mxCell id="C_SRC" value="SOURCE  (legacy SSRS)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#b85450;dashed=1;verticalAlign=top;align=left;spacingLeft=10;spacingTop=6;fontStyle=1;fontSize=13;" parent="1" vertex="1">
                    <mxGeometry x="1040" y="130" width="520" height="380" as="geometry"/>
                </mxCell>
                <mxCell id="C_TGT" value="TARGET  (Power BI Report Server)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#d79b00;dashed=1;verticalAlign=top;align=left;spacingLeft=10;spacingTop=6;fontStyle=1;fontSize=13;" parent="1" vertex="1">
                    <mxGeometry x="1040" y="558" width="520" height="470" as="geometry"/>
                </mxCell>
                <mxCell id="OP" value="Operator / CI&#xa;run.bat (Windows one-stop) · just qg-ps&#xa;Import-Module RsMigration.psd1 → Invoke-RsMigration" style="rounded=8;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="40" y="110" width="250" height="76" as="geometry"/>
                </mxCell>
                <mxCell id="ENV" value=".env / RS_* env vars&#xa;portals · SQL instances · shares · key/db names · hosts" style="rounded=8;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="40" y="216" width="250" height="74" as="geometry"/>
                </mxCell>
                <mxCell id="KEYPW" value="KeyPassword (SecureString)&#xa;never stored — prompted via Read-Host -AsSecureString" style="rounded=8;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="40" y="320" width="250" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="RUNBOOK" value="Invoke-RsMigration — sequences the 9 phases in-process (no child pwsh); aborts on first failure, re-throws naming the failing phase" style="rounded=6;whiteSpace=wrap;html=1;fillColor=#b9e0a5;strokeColor=#82b366;fontSize=12;fontStyle=1;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="360" y="132" width="580" height="46" as="geometry"/>
                </mxCell>
                <mxCell id="P1" value="1  Backup-RsMigrationKey → Backup-RsEncryptionKey  (.snk → source share)" style="rounded=6;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="360" y="188" width="580" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="P2" value="2  Backup-RsMigrationDatabase → Backup-DbaDatabase  (ReportServer + ReportServerTempDB → source share)" style="rounded=6;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="360" y="246" width="580" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="P3" value="3  Copy-RsMigrationBackup (private) → copy both .bak: source share → target share" style="rounded=6;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="360" y="304" width="580" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="P4" value="4  Restore-RsMigrationDatabase → Restore-DbaDatabase  (target share → target SQL)" style="rounded=6;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="360" y="362" width="580" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="P5" value="5  Set-RsMigrationDatabase → Set-RsDatabase -IsExistingDatabase, then Restart-RsService &#39;PowerBIReportServer&#39;" style="rounded=6;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="360" y="420" width="580" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="P6" value="6  Restore-RsMigrationKey → Restore-RsEncryptionKey  (PBIRS instance, local restart)" style="rounded=6;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="360" y="478" width="580" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="P7" value="7  Remove-RsMigrationStaleKey → Invoke-DbaQuery DELETE stale dbo.Keys row  (ShouldProcess / -WhatIf)" style="rounded=6;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="360" y="536" width="580" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="P8" value="8  Import-RsMigrationSubscription → REST v2.0: source GET → target GET/PUT/POST (New-RsMigrationRestSession; include/exclude filter)" style="rounded=6;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="360" y="594" width="580" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="P9" value="9  Invoke-RsMigrationValidation → Invoke-RsReportRender + Test-RsDataSourceConnection + Invoke-DbaQuery (SQL Agent jobs)" style="rounded=6;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="360" y="652" width="580" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="DRYRUN" value="-DryRun (read-only; mutates nothing):&#xa;Export-RsMigrationInventory (SOURCE catalog, Get-RsRestItemDataSource) → Invoke-RsMigrationValidation (TARGET)" style="rounded=6;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="360" y="714" width="580" height="58" as="geometry"/>
                </mxCell>
                <mxCell id="STANDALONE" value="Standalone cmdlets (NOT called by the runbook):&#xa;Set-RsMigrationDataSource (Get-RsRestItemDataSource → repoint) · Reset-RsMigrationEncryptedContent (rskeymgmt -d via Invoke-RsKeyMgmt)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#eafaf1;strokeColor=#82b366;dashed=1;fontSize=11;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="360" y="784" width="580" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="PRIV" value="Private helpers (seams / shared logic): Join-RsMigrationPath · Resolve-RsConnection · New-RsMigrationRestSession · Invoke-RsReportRender · Test-RsDataSourceConnection · Restart-RsService · Invoke-RsKeyMgmt · Copy-RsMigrationBackup" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5fbf2;strokeColor=#b5d6a7;dashed=1;fontSize=11;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" parent="1" vertex="1">
                    <mxGeometry x="360" y="856" width="580" height="84" as="geometry"/>
                </mxCell>
                <mxCell id="SSRS_HOST" value="SSRS report server host&#xa;ReportServer encryption key (.snk)" style="rounded=6;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#b85450;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="1065" y="172" width="470" height="58" as="geometry"/>
                </mxCell>
                <mxCell id="SRC_PORTAL" value="Source report portal&#xa;REST v2.0  /api/v2.0/  (catalog inventory · subscriptions GET)" style="rounded=6;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#b85450;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="1065" y="242" width="470" height="68" as="geometry"/>
                </mxCell>
                <mxCell id="SRC_SQL" value="Source SQL instance&#xa;ReportServer / ReportServerTempDB" style="shape=cylinder3;boundedLbl=1;backgroundOutline=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#b85450;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="1065" y="322" width="470" height="66" as="geometry"/>
                </mxCell>
                <mxCell id="SRC_SHARE" value="Source SMB share&#xa;\\source\FileShare  (.bak files + .snk written here)" style="shape=folder;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#b85450;fontSize=12;verticalAlign=bottom;" parent="1" vertex="1">
                    <mxGeometry x="1065" y="400" width="470" height="62" as="geometry"/>
                </mxCell>
                <mxCell id="TGT_SHARE" value="Target SMB share&#xa;\\target\FileShare  (.bak copied to / restored from)" style="shape=folder;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;verticalAlign=bottom;" parent="1" vertex="1">
                    <mxGeometry x="1065" y="602" width="470" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="TGT_SQL" value="Target SQL instance&#xa;restored ReportServer DB (dbo.Keys)" style="shape=cylinder3;boundedLbl=1;backgroundOutline=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="1065" y="672" width="470" height="68" as="geometry"/>
                </mxCell>
                <mxCell id="PBIRS_HOST" value="PBIRS report server host&#xa;Set-RsDatabase points at restored DB · Restore-RsEncryptionKey · Restart PowerBIReportServer" style="rounded=6;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="1065" y="752" width="470" height="82" as="geometry"/>
                </mxCell>
                <mxCell id="TGT_PORTAL" value="Target report portal&#xa;REST v2.0  /Reports/api/v2.0/&#xa;subscriptions PUT/POST · render + data-source validation" style="rounded=6;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="1065" y="846" width="470" height="84" as="geometry"/>
                </mxCell>
                <mxCell id="LEG" value="Legend&#xa;green = PowerShell phase / cmdlet     orange box = report-server host / SMB share / SQL     yellow = read-only dry-run&#xa;Phases 1 → 9 run in order in-process; any failure aborts the rest and re-throws naming the failing phase.&#xa;.snk key path is the only full path the runbook builds (Join-RsMigrationPath of -SourceSharePath + -KeyFile); every other phase gets share roots + file names and joins internally.&#xa;Both key phases (1 + 6) share the same $keyPath and the same $KeyPassword instance." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fbfbfb;strokeColor=#999999;align=left;spacingLeft=10;fontSize=12;verticalAlign=top;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="-340" y="634" width="660" height="200" as="geometry"/>
                </mxCell>
                <mxCell id="e_op_env" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=11;endArrow=open;" parent="1" source="OP" target="ENV" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e_op_run" value="invoke" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=11;endArrow=block;" parent="1" source="OP" target="RUNBOOK" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e_env_run" value="RS_* params" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=11;dashed=1;endArrow=open;" parent="1" source="ENV" target="RUNBOOK" edge="1">
