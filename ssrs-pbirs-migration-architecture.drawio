                <mxCell id="A4" value="A4  Backup-RsMigrationKey&#10;Backup-RsEncryptionKey → .snk on source share" style="rounded=6;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" parent="1" vertex="1">
