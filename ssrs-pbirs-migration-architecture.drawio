                <mxCell id="e5_setdb" value="5: point PBIRS at restored DB + restart" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=11;strokeColor=#d79b00;" parent="1" source="P5" target="PBIRS_HOST" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
